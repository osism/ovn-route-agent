# ovn-network-agent configuration file
#
# Configuration priority (highest wins):
#   CLI flags > environment variables > config file > defaults
#
# Usage:
#   ovn-network-agent --config /etc/ovn-network-agent/config.yaml

# OVN Southbound DB remote (required)
# Comma-separated for clustered setups (failover).
ovn_sb_remote: "tcp:10.10.0.1:6642,tcp:10.10.0.2:6642,tcp:10.10.0.3:6642"

# OVN Northbound DB remote (required)
ovn_nb_remote: "tcp:10.10.0.1:6641,tcp:10.10.0.2:6641,tcp:10.10.0.3:6641"

# Provider bridge device for kernel routes (default: br-ex)
# bridge_dev: "br-ex"

# VRF name for FRR static routes (default: vrf-provider)
# vrf_name: "vrf-provider"

# Nexthop IP for FRR static routes in the VRF (default: 169.254.0.1)
# veth_nexthop: "169.254.0.1"

# Filter FIPs by CIDRs (default: empty = auto-discover from OVN)
# Only manage NAT IPs within these networks.
# When empty, networks are auto-discovered from Logical_Router_Port.Networks
# of locally-active routers.
# Accepts a single string or a list of CIDRs.
# network_cidr: "192.0.2.0/24"
# network_cidr:
#   - "192.0.2.0/24"
#   - "198.51.100.0/24"

# Link-local IP to add to the bridge device for kernel ARP resolution.
# The kernel needs a source IP on br-ex to perform ARP. This IP is not
# routable and can be the same on all nodes (br-ex has no physical NIC).
# bridge_ip: "169.254.169.254"

# Dedicated routing table ID for FIP routes (default: 0 = main table)
# When set (1-252), routes are placed in a separate table and ip rules
# are added to steer traffic. This avoids polluting the main routing table.
# route_table_id: 100

# Command prefix for ovs-vsctl/ovs-ofctl when OVS runs in a container.
# Set this if ovs-vsctl is not in PATH (e.g. containerized OVS in OSISM/Kolla).
# ovs_wrapper: "docker exec openvswitch_vswitchd"

# Chassisredirect port filter (default: empty = track all routers)
# When empty, the agent automatically discovers all chassisredirect port bindings
# and manages routes for all routers whose gateway is active on this chassis.
# Set to a specific port name (e.g. "cr-lrp-abc123") to restrict the agent to
# tracking only that one router.
# gateway_port: "cr-lrp-abc123"

# Full reconciliation interval (default: 60s)
# reconcile_interval: "60s"

# Log level: debug, info, warn, error (default: info)
# log_level: "info"

# Dry-run mode: connect and reconcile but only log what would be done (default: false)
# dry_run: false

# Remove all managed routes on shutdown (default: true)
# Set to false to keep routes in place when the agent stops.
# cleanup_on_shutdown: true

# Drain HA gateways before shutdown (default: true)
# When enabled, the agent lowers its Gateway_Chassis priority to 0 on shutdown,
# causing OVN to migrate chassisredirect ports to standby chassis before cleanup.
# This eliminates the traffic disruption window between BGP withdrawal and OVN failover.
# Note: Priorities are NOT restored on shutdown. Neutron's L3 HA scheduler will
# rebalance when the chassis returns.
# drain_on_shutdown: true

# Maximum time to wait for gateway drain (default: 60s)
# After this timeout, the agent proceeds with normal shutdown even if some
# gateways have not yet migrated.
# drain_timeout: "60s"

# FRR prefix-list to manage dynamically (default: ANNOUNCED-NETWORKS)
# When set, the agent adds/removes "permit <network> ge 32 le 32" entries
# for each discovered provider network. This replaces hardcoded prefix-list
# entries in the FRR configuration. Set to empty string to disable.
# frr_prefix_list: "ANNOUNCED-NETWORKS"

# Grace period before cleaning up OVN NB entries from chassis that have
# disappeared from the SB Chassis table (default: 5m).
# Any surviving agent will detect missing chassis and clean up their stale
# static routes and MAC bindings after this period.
# Set to "0" to disable stale chassis cleanup.
# stale_chassis_grace_period: "5m"

# Veth VRF route leaking (replaces contrib/veth-vrf-leak.sh)
# Creates a veth pair for selective route leaking between default VRF and
# the provider VRF. Per-network routes are managed dynamically based on
# discovered or configured networks.
# veth_leak_enabled: true

# IP of the veth-provider side (default: computed from veth_nexthop + 1)
# veth_provider_ip: "169.254.0.2"

# Routing table ID for the leak default route (default: 200, must be 1-252)
# Must differ from route_table_id.
# veth_leak_table_id: 200

# Policy rule priority for veth leak rules (default: 2000)
# veth_leak_rule_priority: 2000

# =============================================================================
# Port forwarding (DNAT)
# =============================================================================
# Forward traffic arriving at anycast VIP addresses to internal backends.
# VIPs are typically announced via BGP from a loopback interface in vrf-provider.
# Client IP is preserved (no masquerade); return traffic uses connmark-based
# policy routing through the veth pair.
#
# Requires: veth_leak_enabled: true, nft binary in PATH.
#
# Device for VIP addresses in VRF (default: "loopback1")
# port_forward_dev: "loopback1"
#
# Dedicated routing table for DNAT return traffic (default: 201)
# Must differ from route_table_id and veth_leak_table_id.
# port_forward_table_id: 201
#
# Conntrack zone for DNAT flows (default: 64000, range 1-65535).
# Must not collide with OVN/OVS conntrack zones. OVN assigns zones
# per logical datapath starting from low numbers. The high default
# avoids collisions; only change if 64000 conflicts in your setup.
# port_forward_ct_zone: 64000
#
# Enable udp/tcp_l3mdev_accept sysctl (default: false).
# Required when a DNAT backend runs on the same host but in a different
# VRF than the VIP (e.g. backend on loopback0 in default VRF, VIP on
# loopback1 in provider VRF). This is a global sysctl that allows ALL
# sockets to receive packets from any VRF — only enable when needed.
# port_forward_l3mdev_accept: false
#
# port_forwards:
#   - vip: "198.51.100.10"
#     manage_vip: true         # agent adds/removes this VIP on port_forward_dev
#     masquerade: true         # VIP-level default: rules inherit unless overridden
#     rules:
#       # Local backend (same host): disable masquerade.
#       # Replies use output_ctzone/output_fwmark chains.
#       - proto: udp
#         port: 53
#         dest_addr: "10.0.0.200"
#         dest_port: 1053                # port translation: VIP:53 -> 10.0.0.200:1053
#         masquerade: false              # per-rule override: no SNAT for local backend
#       - proto: tcp
#         port: 53
#         dest_addr: "10.0.0.200"
#         dest_port: 1053
#         masquerade: false
#       # Remote backend (different host): inherits masquerade: true from VIP.
#       - proto: tcp
#         port: 80
#         dest_addr: "10.0.0.100"       # single backend
#       - proto: tcp
#         port: 443
#         dest_addr: "10.0.0.100"
#       # Multiple backends with sticky hashing:
#       - proto: udp
#         port: 5353
#         dest_addrs:                    # multiple backends: sticky source-IP hashing
#           - "10.0.0.200"
#           - "10.0.0.201"
#           - "10.0.0.202"
#         dest_port: 1053
#   - vip: "198.51.100.20"
#     manage_vip: false         # VIP already exists on the interface
#     rules:
#       - proto: tcp
#         port: 443
#         dest_addr: "10.0.0.100"
